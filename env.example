# ══════════════════════════════════════════════
#  Lumina AI  環境変数
#  ローカル開発用: cp .env.example .env して使う
#  Railway本番:   Railwayの Variables 画面で直接設定
# ══════════════════════════════════════════════

# ── ① OpenAI（必須）────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# ── ② JWT シークレット（必須）──────────────────
SECRET_KEY=lumina-change-this-in-production
JWT_EXPIRE_DAYS=30

# ── ③ DB（Railway では自動設定・ローカルのみ使用）
# Railwayでは DATABASE_URL が自動注入されるため不要
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_suite
DB_USER=ai_suite_user
DB_PASSWORD=ai_suite_pass

# ── ④ 楽天（任意）──────────────────────────────
# 旅行・買い物・家電・DIY AI で実際の商品・ホテル検索に使用
# https://webservice.rakuten.co.jp/
RAKUTEN_APP_ID=

# ── ⑤ Google Maps（任意）──────────────────────
# 周辺スポット・スーパー・店舗検索に使用
# https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=
# ── ⑥ メール送信（任意）────────────────────────────────────
# Railway では SMTP 直接接続がブロックされるため SendGrid HTTP API を推奨
#
# 【Railway 本番環境 推奨: SendGrid】
# 1. https://sendgrid.com で無料登録（月100通無料）
# 2. Settings → API Keys → Create API Key（Mail Send権限）
# 3. Settings → Sender Authentication → Verify a Single Sender でメール認証
MAIL_DRIVER=sendgrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM=Lumina AI <your-address@gmail.com>

# 【ローカル開発用: Gmail SMTP】
# ※ Google アカウント → セキュリティ → アプリパスワードで発行した 16 文字のパスワードを使用
# MAIL_DRIVER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-address@gmail.com
# SMTP_PASS=xxxxxxxxxxxxxxxx
# SMTP_FROM=Lumina AI <your-address@gmail.com>

# 予算アラートの送信先管理者メールアドレス
ADMIN_EMAIL=admin@example.com

# フロントエンドURL（管理画面リンクに使用）
APP_URL=https://aiassistant-production-264e.up.railway.app
# ── ⑦ ツアー検索（RapidAPI Google Search）────────────────────
# 既存の RAPIDAPI_KEY をそのまま使用（追加のキー不要）
# RapidAPIダッシュボードで追加購読が必要:
#   1. https://rapidapi.com/neoscrap-net/api/google-search72 にアクセス
#   2. "Subscribe to Test" → 無料プランを選択（月100〜500リクエスト）
#   3. 既存の RAPIDAPI_KEY のままで動作する（追加設定不要）
# ※ RAPIDAPI_KEY は ④ 航空券検索・海外ホテル検索と共用
# （google-search72 の購読は無料・追加のAPIキーは不要）
