# ══════════════════════════════════════════════
#  Lumina AI  環境変数
#  ローカル開発用: cp .env.example .env して使う
#  Railway本番:   Railwayの Variables 画面で直接設定
# ══════════════════════════════════════════════

# ── ① OpenAI（必須）────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx

# ── ② JWT シークレット（必須）──────────────────
SECRET_KEY=lumina-change-this-in-production
JWT_EXPIRE_DAYS=30

# ── ③ DB（Railway では自動設定・ローカルのみ使用）
# Railwayでは DATABASE_URL が自動注入されるため不要
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_suite
DB_USER=ai_suite_user
DB_PASSWORD=ai_suite_pass

# ── ④ 楽天（任意）──────────────────────────────
# 旅行・買い物・家電・DIY AI で実際の商品・ホテル検索に使用
# https://webservice.rakuten.co.jp/
RAKUTEN_APP_ID=

# ── ⑤ Google Maps（任意）──────────────────────
# 周辺スポット・スーパー・店舗検索に使用
# https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=
